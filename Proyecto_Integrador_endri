import pandas as pd
import pymysql
import sqlite3
import warnings
warnings.filterwarnings("ignore", category=UserWarning)
import connect_sqlite
import matplotlib.pyplot as plt



# Conexión a la base de datos SQLite
conn = connect_sqlite.connect_sqlite()
#1 Cargar tablas
df_socios = pd.read_sql("SELECT * FROM socios", conn)
df_libros = pd.read_sql("SELECT * FROM libros", conn)
df_prestamos = pd.read_sql("SELECT * FROM prestamos", conn)

print(df_libros)

 # JOIN completo
df = pd.merge(df_prestamos, df_socios, left_on="socio_id", right_on="id")
df = pd.merge(df, df_libros, left_on="libro_id", right_on="id")

#2 Socios más activos
prestamos_por_socio = df.groupby("nombre")["socio_id"].count().reset_index()
prestamos_por_socio.columns = ["socio", "cantidad_prestamos"]

# Gráfico
prestamos_por_socio.plot(kind="bar", x="socio", y="cantidad_prestamos", 
legend=False)
plt.title("Préstamos por socio")
plt.xlabel("Socio")
plt.ylabel("Cantidad de préstamos")
plt.show()

#3 Libros más prestados
prestamos_por_libro = df.groupby("titulo")["libro_id"].count().reset_index()
prestamos_por_libro.columns = ["libro", "cantidad_prestamos"]

#Gráfico
prestamos_por_libro.plot(kind="bar", x="libro", y="cantidad_prestamos", legend=False)
plt.title("Préstamos por libro")
plt.xlabel("Libro")
plt.ylabel("Cantidad de préstamos")
plt.show()


connect_sqlite.disconnect_sqlite(conn)